{
  "name": "timeline-notes",
  "version": "1.0.0",
  "description": "时间轴便签 - 带提醒的桌面便签应用",
  "main": "main.js",
  "author": "wangkun",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.wangkun.timeline-notes",
    "productName": "时间轴便签",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*"
    ],
    "win": {
      "icon": "src-tauri/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["ia32", "x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
