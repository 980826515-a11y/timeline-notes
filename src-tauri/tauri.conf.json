{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "时间轴便签",
  "version": "1.0.0",
  "identifier": "com.wangkun.timeline-notes",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": null,
    "beforeBuildCommand": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "时间轴便签",
        "width": 800,
        "height": 900,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "带提醒的桌面便签应用",
    "longDescription": "时间轴便签 - 记录每一条待办与想法，到点提醒"
  }
}
